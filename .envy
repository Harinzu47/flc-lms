####################################
# Application
####################################

APP_NAME="FLC LMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://103.127.137.24

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

####################################
# Logging
####################################

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

####################################
# Database
####################################

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flc_lms
DB_USERNAME=flc_user
DB_PASSWORD=kodokzuma123

####################################
# Session
####################################

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

####################################
# Cache
####################################

CACHE_STORE=redis

####################################
# Queue
####################################

QUEUE_CONNECTION=redis

####################################
# Redis
####################################

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

####################################
# Mail
####################################

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@domainanda.com
MAIL_FROM_NAME="${APP_NAME}"

####################################
# Filesystem
####################################

FILESYSTEM_DISK=local

####################################
# Broadcast
####################################

BROADCAST_CONNECTION=log

####################################
# AWS S3 (Optional)
####################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

####################################
# Vite
####################################

VITE_APP_NAME="${APP_NAME}"

